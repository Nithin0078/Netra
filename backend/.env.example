# Netra Backend Environment Variables Template

# FastAPI config
JWT_SECRET=netra_super_secure_vault_secret_key_99812
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Firebase Configuration
# Use the Firestore Emulator for local testing:
FIRESTORE_EMULATOR_HOST=localhost:8080
# Set these to connect to a live Firebase project:
FIREBASE_PROJECT_ID=netra-firebase-project
FIREBASE_SERVICE_ACCOUNT_KEY_PATH=
# Alternatively, paste your Firebase service account JSON string directly (useful for Render deployment):
FIREBASE_CREDENTIALS=

# Cloudinary Credentials (Optional - Falls back to local filesystem static/uploads folder if left blank)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
